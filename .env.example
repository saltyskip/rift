# ── Server ──
HOST=0.0.0.0
PORT=3000

# ── MongoDB (optional — server boots without it, auth disabled) ──
MONGO_URI=
MONGO_DB=rift

# ── Sentry (optional — empty = disabled) ──
SENTRY_DSN=

# ── Email verification via Resend (https://resend.com) ──
RESEND_API_KEY=
RESEND_FROM_EMAIL=Rift <noreply@updates.riftl.ink>

# ── Auth ──
PUBLIC_URL=http://localhost:3000
FREE_DAILY_LIMIT=5

# ── x402 Payments (optional — empty = disabled) ──
# Get keys from https://portal.cdp.coinbase.com
X402_ENABLED=false
X402_FACILITATOR_URL=https://facilitator.x402.org
X402_RECIPIENT=
X402_PRICE=0.01
X402_DESCRIPTION=Rift API request
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# ── Custom domains ──
PRIMARY_DOMAIN=riftl.ink

# ── Marketing site ──
NEXT_PUBLIC_API_URL=http://localhost:3000
