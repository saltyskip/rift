#!/bin/bash
set -e

# ── Mobile SDK: check core crate for UniFFI violations ──
if [ -d "client/mobile/core/src" ]; then
    client/mobile/.githooks/pre-commit "client/mobile/core/src"
fi

# ── Web SDK: rebuild IIFE if source changed ──
if git diff --cached --name-only | grep -q "^sdk/web/src/"; then
    echo "Web SDK source changed — rebuilding..."
    cd sdk/web
    npm run build --silent
    cp dist/index.global.js ../../server/src/sdk/rift.js
    cd ../..
    git add server/src/sdk/rift.js
    echo "Web SDK IIFE updated and staged."
fi

# ── Rust crates: rustfmt check ──
# Catches whitespace/wrap drift before push so CI's fmt step doesn't bounce
# branches that compiled + passed tests locally. Clippy + tests stay in CI —
# they're too slow for a pre-commit gate.
#
# The repo is several independent cargo projects (not a workspace), so each
# has to be fmt-checked separately. Mobile crates have their own pre-commit
# invoked at the top of this file.
staged_rs=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^(server|client/core|client/cli)/.*\.rs$' || true)
if [ -n "$staged_rs" ]; then
    for manifest in \
        server/Cargo.toml \
        server/rift-macros/Cargo.toml \
        client/core/Cargo.toml \
        client/cli/Cargo.toml; do
        if ! cargo fmt --manifest-path "$manifest" -- --check >/dev/null 2>&1; then
            echo "rustfmt would change files under $(dirname "$manifest")/. Run:" >&2
            echo "  cargo fmt --manifest-path $manifest" >&2
            echo "then re-stage and commit." >&2
            exit 1
        fi
    done
fi
